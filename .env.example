# Local environment variables for Knowlix

DATABASE_URL=postgresql://<user>:<pass>@<host>/<db>?sslmode=verify-full&channel_binding=require
BETTER_AUTH_SECRET=<strong-random-secret>
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated admin emails (server + client must match for signup UI hints)
ADMIN_EMAILS=admin@example.com
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com

# Legacy single bootstrap email (still supported)
# ADMIN_BOOTSTRAP_EMAIL=admin@example.com
# NEXT_PUBLIC_ADMIN_BOOTSTRAP_EMAIL=admin@example.com
